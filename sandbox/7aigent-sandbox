#!/bin/sh
# 7aigent-sandbox — launch the sandboxed IJulia kernel
#
# Usage: 7aigent-sandbox <workspace-path>
#
# Prints the absolute path of kernel.json to stdout, then blocks until the
# container exits.  Set SANDBOX_DRY_RUN=1 to generate files and exit without
# starting the container (used by tests).
#
# Build-time placeholders filled in by the Nix installPhase:
#   @rootfs_dir@      — path to the static rootfs skeleton
#   @config_template@ — path to the OCI config.json template
#   @runsc@           — path to the runsc (gvisor) binary

set -e

WORKSPACE="$1"

# S21: require exactly one argument
if [ -z "$WORKSPACE" ]; then
    echo "Usage: 7aigent-sandbox <workspace-path>" >&2
    exit 1
fi

# S22: workspace must exist and be a directory
if [ ! -d "$WORKSPACE" ]; then
    echo "Error: workspace '$WORKSPACE' does not exist or is not a directory" >&2
    exit 1
fi

WORKSPACE=$(realpath "$WORKSPACE")

# Create runtime directory
RUNTIME_DIR=$(mktemp -d /tmp/7aigent-XXXXXX)

# S17: remove runtime directory on exit (clean or signal)
cleanup() {
    rm -rf "$RUNTIME_DIR"
}
trap cleanup EXIT INT TERM

SOCKETS_DIR="$RUNTIME_DIR/sockets"
BUNDLE_DIR="$RUNTIME_DIR/bundle"
mkdir -p "$SOCKETS_DIR" "$BUNDLE_DIR"

# Copy rootfs skeleton (empty mount-point directories only)
cp -r @rootfs_dir@ "$BUNDLE_DIR/rootfs"

# S9: generate a fresh UUID4 as the HMAC key
KEY=$(cat /proc/sys/kernel/random/uuid)

# S8, S9: write two Jupyter connection files:
#   kernel.json         — for external clients (host paths for IPC sockets)
#   kernel-internal.json — for Julia inside the container (container paths)
cat > "$SOCKETS_DIR/kernel.json" << EOF
{
  "transport": "ipc",
  "ip": "$SOCKETS_DIR/kernel",
  "shell_port": 1,
  "iopub_port": 2,
  "stdin_port": 3,
  "control_port": 4,
  "hb_port": 5,
  "signature_scheme": "hmac-sha256",
  "key": "$KEY"
}
EOF

cat > "$SOCKETS_DIR/kernel-internal.json" << EOF
{
  "transport": "ipc",
  "ip": "/sockets/kernel",
  "shell_port": 1,
  "iopub_port": 2,
  "stdin_port": 3,
  "control_port": 4,
  "hb_port": 5,
  "signature_scheme": "hmac-sha256",
  "key": "$KEY"
}
EOF

# Instantiate the OCI config from the template (fill runtime placeholders).
# If the workspace has no .git directory, strip the read-only .git bind-mount
# so that runsc doesn't fail trying to bind a non-existent source.
if [ -d "$WORKSPACE/.git" ]; then
    GIT_MOUNT_FILTER="cat"
else
    GIT_MOUNT_FILTER='grep -v "workspace/\.git"'
fi
sed \
    -e "s|@WORKSPACE@|$WORKSPACE|g" \
    -e "s|@SOCKETS_DIR@|$SOCKETS_DIR|g" \
    @config_template@ | eval "$GIT_MOUNT_FILTER" > "$BUNDLE_DIR/config.json"

# S15: print kernel.json path before the container starts accepting connections
echo "$SOCKETS_DIR/kernel.json"

# Dry-run mode: generate files but do not start the container (for tests)
if [ "${SANDBOX_DRY_RUN:-0}" = "1" ]; then
    # Prevent cleanup trap from removing the files the test needs to inspect.
    # Re-register a no-op trap; the test runner's process exit will reclaim /tmp.
    trap '' EXIT INT TERM
    exit 0
fi

# S1, S2: run the container under gvisor with KVM platform and no network.
# --rootless: run without root privileges (skips cgroup setup).
# --host-uds=create: allow the kernel to create ZMQ IPC sockets on the
#   bind-mounted /sockets directory (host Unix-domain socket creation).
#
# SANDBOX_RUNNER=bwrap selects bubblewrap as an alternative runner for
# environments where runsc/gvisor is unavailable (e.g. CI, nested containers).
# bwrap provides namespace isolation but NOT gvisor's syscall filtering.
# Only use for development/testing — not for production security.
if [ "${SANDBOX_RUNNER:-}" = "bwrap" ]; then
    # Extract env and args from the OCI config using the Julia binary directly.
    # bwrap does not read OCI bundles; we reconstruct the invocation manually.
    JULIA=@julia@
    SANDBOX_OUT=@sandbox_out@
    CODETR=@codeTree@

    exec @bwrap@ \
        --ro-bind /nix/store /nix/store \
        --bind "$WORKSPACE" /workspace \
        $( [ -d "$WORKSPACE/.git" ] && echo "--ro-bind $WORKSPACE/.git /workspace/.git" ) \
        --bind "$SOCKETS_DIR" /sockets \
        --tmpfs /tmp \
        --tmpfs /home/julia \
        --dev /dev \
        --proc /proc \
        --unshare-pid \
        --unshare-ipc \
        --unshare-uts \
        --die-with-parent \
        --chdir /workspace \
        --setenv HOME /home/julia \
        --setenv JULIA_DEPOT_PATH "/tmp/julia-depot:$SANDBOX_OUT/julia-depot" \
        --setenv JULIA_PROJECT "$CODETR/project" \
        --setenv JULIA_LOAD_PATH "@:@v#.#:@stdlib" \
        --setenv JULIA_PKG_SERVER "" \
        --setenv PATH "$JULIA/bin" \
        -- "$JULIA/bin/julia" \
        -t 2 \
        --startup-file=no \
        "$SANDBOX_OUT/share/sandbox/startup.jl" \
        "/sockets/kernel-internal.json"
fi

exec @runsc@ \
    --rootless \
    --platform=kvm \
    --network=none \
    --host-uds=create \
    run \
    --bundle "$BUNDLE_DIR" \
    "7aigent-$(basename "$RUNTIME_DIR")"
